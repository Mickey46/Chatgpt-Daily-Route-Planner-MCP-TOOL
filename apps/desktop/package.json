{
  "name": "bcba-route-planner",
  "version": "0.1.0",
  "description": "Kanban + calendar route planner for BCBA scheduling, with an MCP server ChatGPT can connect to.",
  "private": true,
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json && mkdir -p dist/main/db && cp src/main/db/schema.sql dist/main/db/schema.sql",
    "build": "npm run build:renderer && npm run build:main",
    "build:native": "cd native/RouteHelper && swift build -c release",
    "start": "npm run build && electron .",
    "dist": "npm run build && npm run build:native && electron-builder",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.9.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
