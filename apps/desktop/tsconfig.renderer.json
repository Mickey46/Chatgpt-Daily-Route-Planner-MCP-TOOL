{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/renderer",
    "rootDir": "src/renderer/src",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": ["src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx"]
}
